{
  "name": "octothorpe",
  "version": "0.1.0",
  "description": "A Typora-like Markdown editor with document management",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "gen:prefs": "node scripts/gen-preferences.mjs",
    "dev": "node scripts/gen-preferences.mjs && vite",
    "build": "node scripts/gen-preferences.mjs && vite build",
    "preview": "vite preview",
    "check": "node scripts/gen-preferences.mjs && svelte-check --tsconfig ./tsconfig.json",
    "tauri": "tauri"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/language": "^6.10.3",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/search": "^6.5.7",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.34.1",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.1",
    "@lezer/markdown": "^1.3.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2",
    "ajv": "^8.17.1",
    "codemirror": "^6.0.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "json-schema-to-typescript": "^15.0.3",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
