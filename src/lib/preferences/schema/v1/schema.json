{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "octothorpe://preferences/v1",
  "title": "Octothorpe Preferences",
  "type": "object",
  "additionalProperties": false,
  "x-ui": {
    "categories": [
      { "id": "files", "label": "Files" },
      { "id": "editor", "label": "Editor" },
      { "id": "markdown", "label": "Markdown" },
      { "id": "image", "label": "Image" },
      { "id": "appearance", "label": "Appearance" }
    ]
  },
  "properties": {
    "version": {
      "type": "integer",
      "description": "Schema version the settings were written against.",
      "x-ui": { "hidden": true }
    },
    "editor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "wordWrap": {
          "type": "boolean",
          "default": true,
          "title": "Word Wrap",
          "description": "Wrap long lines to the editor width instead of scrolling horizontally.",
          "x-ui": { "category": "editor", "section": "Behavior", "control": "toggle", "order": 1 }
        },
        "indentSize": {
          "type": "string",
          "default": "4",
          "enum": ["2", "3", "4", "5"],
          "title": "Indent Size",
          "description": "Number of spaces per indent level (indentation always uses spaces).",
          "x-ui": {
            "category": "editor",
            "section": "Indentation",
            "control": "select",
            "order": 1,
            "options": [
              { "value": "2", "label": "2" },
              { "value": "3", "label": "3" },
              { "value": "4", "label": "4" },
              { "value": "5", "label": "5" }
            ]
          }
        },
        "prettyIndent": {
          "type": "boolean",
          "default": false,
          "title": "Pretty indentation",
          "description": "Pad list and quote markers to the indent width (e.g. \"-   item\") so nested content lines up.",
          "x-ui": { "category": "editor", "section": "Indentation", "control": "toggle", "order": 2 }
        },
        "autoPairBrackets": {
          "type": "boolean",
          "default": true,
          "title": "Auto pair brackets and quotes",
          "description": "Automatically insert the closing bracket or quote when you type an opening one.",
          "x-ui": { "category": "editor", "section": "Auto Pair", "control": "toggle", "order": 1 }
        },
        "autoPairMarkdown": {
          "type": "boolean",
          "default": false,
          "title": "Auto pair common Markdown syntax",
          "description": "Also auto-pair Markdown emphasis markers (* _ ~ `).",
          "x-ui": { "category": "editor", "section": "Auto Pair", "control": "toggle", "order": 2 }
        },
        "emojiAutocomplete": {
          "type": "boolean",
          "default": true,
          "title": "Enable autocomplete for Emojis",
          "description": "Suggest emojis while typing a `:name:` shortcode.",
          "x-ui": { "category": "editor", "section": "Auto Complete", "control": "toggle", "order": 1 }
        },
        "revealSourceOnFocus": {
          "type": "boolean",
          "default": true,
          "title": "Display source for simple blocks on focus",
          "description": "Reveal the Markdown source (heading #, quote >, list markers) on the line the cursor is on. When off, those blocks stay rendered even while focused.",
          "x-ui": { "category": "editor", "section": "Live Rendering", "control": "toggle", "order": 1 }
        },
        "copyMarkdownAsPlain": {
          "type": "boolean",
          "default": false,
          "title": "Copy Markdown source as plain text",
          "description": "Ctrl+C copies the text with Markdown syntax stripped, instead of the raw source.",
          "x-ui": { "category": "editor", "section": "Copy Behavior", "control": "toggle", "order": 1 }
        },
        "copyWholeLine": {
          "type": "boolean",
          "default": true,
          "title": "Copy or cut the whole line when nothing is selected",
          "description": "With no selection, Ctrl+C / Ctrl+X act on the current line.",
          "x-ui": { "category": "editor", "section": "Copy Behavior", "control": "toggle", "order": 2 }
        },
        "lineEnding": {
          "type": "string",
          "default": "lf",
          "enum": ["lf", "crlf"],
          "title": "Default Line Ending",
          "description": "Line ending used when saving files and creating new documents.",
          "x-ui": {
            "category": "editor",
            "section": "Line Ending",
            "control": "select",
            "order": 1,
            "options": [
              { "value": "lf", "label": "LF (Unix Style)" },
              { "value": "crlf", "label": "CRLF (Windows Style)" }
            ]
          }
        },
        "spellCheck": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "off"],
          "title": "Spell Check",
          "description": "Enable the system spell-checker in the editor (the language is chosen by the OS).",
          "x-ui": {
            "category": "editor",
            "section": "Spell Check",
            "control": "select",
            "order": 1,
            "options": [
              { "value": "auto", "label": "Auto Detect Language" },
              { "value": "off", "label": "Off" }
            ]
          }
        }
      }
    },
    "markdown": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inlineMath": {
          "type": "boolean",
          "default": true,
          "title": "Render inline math",
          "description": "Render inline $…$ LaTeX with KaTeX. When off, $ stays literal in prose (e.g. prices). Block math ($$…$$ and ```math) always renders.",
          "x-ui": { "category": "markdown", "section": "Math", "control": "toggle", "order": 1 }
        }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "insertAction": {
          "type": "string",
          "default": "none",
          "enum": ["none", "currentFolder", "assets", "filenameAssets", "custom"],
          "title": "When Insert",
          "description": "What to do with an image dropped into the editor.",
          "x-ui": {
            "category": "image",
            "section": "When Inserting",
            "control": "select",
            "order": 1,
            "options": [
              { "value": "none", "label": "No special action" },
              { "value": "currentFolder", "label": "Copy image to the current folder (./)" },
              { "value": "assets", "label": "Copy image to ./assets" },
              { "value": "filenameAssets", "label": "Copy image to ./${filename}.assets" },
              { "value": "custom", "label": "Copy image to custom folder" }
            ]
          }
        },
        "customFolder": {
          "type": "string",
          "default": "./${filename}.assets",
          "title": "Custom Folder",
          "description": "Relative path to the current folder (begins with './' or '../'), or an absolute path. ${filename} stands for the current document's name.",
          "x-ui": {
            "category": "image",
            "section": "When Inserting",
            "control": "text",
            "order": 2,
            "showWhen": { "key": "image.insertAction", "equals": "custom" }
          }
        },
        "applyToLocal": {
          "type": "boolean",
          "default": true,
          "title": "Apply above rules to local images",
          "description": "Copy images that come from the local filesystem.",
          "x-ui": { "category": "image", "section": "When Inserting", "control": "toggle", "order": 3 }
        },
        "applyToOnline": {
          "type": "boolean",
          "default": true,
          "title": "Apply above rules to online images",
          "description": "Download and copy images that come from an http(s) URL.",
          "x-ui": { "category": "image", "section": "When Inserting", "control": "toggle", "order": 4 }
        },
        "useRelativePath": {
          "type": "boolean",
          "default": true,
          "title": "Use relative path if possible",
          "description": "Link to images with a path relative to the document instead of an absolute one.",
          "x-ui": { "category": "image", "section": "Preferred Image Syntax", "control": "toggle", "order": 1 }
        },
        "addDotSlash": {
          "type": "boolean",
          "default": false,
          "title": "Add ./ for relative path",
          "description": "Prefix relative image paths with \"./\".",
          "x-ui": { "category": "image", "section": "Preferred Image Syntax", "control": "toggle", "order": 2 }
        },
        "autoEscape": {
          "type": "boolean",
          "default": false,
          "title": "Auto escape image URL when insert",
          "description": "Percent-encode special characters in the inserted image path.",
          "x-ui": { "category": "image", "section": "Preferred Image Syntax", "control": "toggle", "order": 3 }
        }
      }
    },
    "appearance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fontSizeMode": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "custom"],
          "title": "Font Size",
          "description": "Use the recommended editor font size, or set your own.",
          "x-ui": {
            "category": "appearance",
            "section": "Font",
            "control": "radio",
            "order": 1,
            "options": [
              { "value": "auto", "label": "Auto" },
              { "value": "custom", "label": "Customized", "field": "appearance.fontSize" }
            ]
          }
        },
        "fontSize": {
          "type": "integer",
          "default": 15,
          "minimum": 8,
          "maximum": 40,
          "title": "Font Size",
          "description": "Editor font size, in pixels.",
          "x-ui": {
            "category": "appearance",
            "section": "Font",
            "control": "number",
            "order": 2,
            "inline": true,
            "unit": "px"
          }
        },
        "lineHeight": {
          "type": "number",
          "default": 1.6,
          "minimum": 1.0,
          "maximum": 2.5,
          "title": "Line Height",
          "description": "Vertical spacing between lines, as a multiple of the font size.",
          "x-ui": { "category": "appearance", "section": "Font", "control": "number", "step": 0.1, "order": 3 }
        },
        "zoom": {
          "type": "string",
          "default": "100",
          "enum": ["50", "67", "75", "80", "90", "100", "110", "125", "150", "175", "200"],
          "title": "Zoom",
          "description": "Scale the whole application.",
          "x-ui": {
            "category": "appearance",
            "section": "Zoom",
            "control": "select",
            "order": 1,
            "options": [
              { "value": "50", "label": "50%" },
              { "value": "67", "label": "67%" },
              { "value": "75", "label": "75%" },
              { "value": "80", "label": "80%" },
              { "value": "90", "label": "90%" },
              { "value": "100", "label": "100%" },
              { "value": "110", "label": "110%" },
              { "value": "125", "label": "125%" },
              { "value": "150", "label": "150%" },
              { "value": "175", "label": "175%" },
              { "value": "200", "label": "200%" }
            ]
          }
        },
        "zoomWithCtrlWheel": {
          "type": "boolean",
          "default": false,
          "title": "Zoom with Ctrl + mouse wheel",
          "description": "Hold Ctrl and scroll the mouse wheel to change the zoom level.",
          "x-ui": { "category": "appearance", "section": "Zoom", "control": "toggle", "order": 2 }
        },
        "showStatusBar": {
          "type": "boolean",
          "default": true,
          "title": "Show status bar",
          "description": "Show the information bar at the bottom of the window.",
          "x-ui": { "category": "appearance", "section": "Status Bar", "control": "toggle", "order": 1 }
        },
        "theme": {
          "type": "string",
          "default": "system",
          "enum": ["system", "light", "dark"],
          "title": "Theme",
          "description": "Color theme. \"System\" follows the operating system setting.",
          "x-ui": {
            "category": "appearance",
            "section": "Theme",
            "control": "select",
            "order": 1,
            "options": [
              { "value": "system", "label": "Follow System" },
              { "value": "light", "label": "Light" },
              { "value": "dark", "label": "Dark" }
            ]
          }
        }
      }
    },
    "files": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "onLaunch": {
          "type": "string",
          "default": "restoreFilesAndFolders",
          "enum": ["openNewFile", "restoreFolders", "restoreFilesAndFolders", "openCustomFolder"],
          "title": "On Launch",
          "description": "What to open when the app starts.",
          "x-ui": {
            "category": "files",
            "section": "General",
            "control": "select",
            "order": 1,
            "options": [
              { "value": "openNewFile", "label": "Open new file" },
              { "value": "restoreFolders", "label": "Restore last closed folders" },
              { "value": "restoreFilesAndFolders", "label": "Restore last closed files and folders" },
              { "value": "openCustomFolder", "label": "Open custom folder" }
            ]
          }
        },
        "collapsibleOutline": {
          "type": "boolean",
          "default": false,
          "title": "Collapsible Outline on Left Panel",
          "description": "Show the document outline as a collapsible section in the left panel.",
          "x-ui": { "category": "files", "section": "General", "control": "toggle", "order": 2 }
        },
        "defaultExtension": {
          "type": "string",
          "default": ".md",
          "enum": [".md", ".markdown", ".txt"],
          "title": "Default File Type / Extension",
          "description": "Extension used when creating new documents.",
          "x-ui": {
            "category": "files",
            "section": "General",
            "control": "select",
            "order": 3,
            "options": [
              { "value": ".md", "label": "Markdown (.md)" },
              { "value": ".markdown", "label": "Markdown (.markdown)" },
              { "value": ".txt", "label": "Plain Text (.txt)" }
            ]
          }
        },
        "autoSave": {
          "type": "boolean",
          "default": true,
          "title": "Auto Save",
          "description": "Automatically save changes to disk as you edit.",
          "x-ui": { "category": "files", "section": "Save & Recover", "control": "toggle", "order": 1 }
        },
        "saveOnSwitch": {
          "type": "boolean",
          "default": true,
          "title": "Save without asking when switching files",
          "description": "When switching files in the side panel, save changes without prompting.",
          "x-ui": { "category": "files", "section": "Save & Recover", "control": "toggle", "order": 2 }
        },
        "recordRecent": {
          "type": "boolean",
          "default": true,
          "title": "Record recent files and folders",
          "description": "Keep a list of recently opened files and folders.",
          "x-ui": { "category": "files", "section": "Recent Locations", "control": "toggle", "order": 1 }
        },
        "onDropFolder": {
          "type": "string",
          "default": "open",
          "enum": ["open", "insertLink"],
          "title": "When drop folder",
          "description": "Action taken when a folder is dropped into the window.",
          "x-ui": {
            "category": "files",
            "section": "Drag & Drop",
            "control": "select",
            "order": 1,
            "options": [
              { "value": "open", "label": "Open in Octothorpe" },
              { "value": "insertLink", "label": "Insert Folder Link" }
            ]
          }
        },
        "onDropMarkdown": {
          "type": "string",
          "default": "open",
          "enum": ["open", "insertLink"],
          "title": "When drop markdown file",
          "description": "Action taken when a Markdown file is dropped into the window.",
          "x-ui": {
            "category": "files",
            "section": "Drag & Drop",
            "control": "select",
            "order": 2,
            "options": [
              { "value": "open", "label": "Open in Octothorpe" },
              { "value": "insertLink", "label": "Insert File Link" }
            ]
          }
        },
        "onDropImportable": {
          "type": "string",
          "default": "import",
          "enum": ["import", "insertLink"],
          "title": "When drop files that can be imported",
          "description": "Action taken when an importable file is dropped into the window.",
          "x-ui": {
            "category": "files",
            "section": "Drag & Drop",
            "control": "select",
            "order": 3,
            "options": [
              { "value": "import", "label": "Import File" },
              { "value": "insertLink", "label": "Insert File Link" }
            ]
          }
        }
      }
    }
  }
}
