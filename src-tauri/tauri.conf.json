{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Octothorpe",
  "version": "0.1.0",
  "identifier": "com.octothorpe.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Octothorpe",
        "width": 1100,
        "height": 720
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Menghua Xiao",
    "category": "Productivity",
    "copyright": "Copyright © 2026 Menghua Xiao",
    "shortDescription": "A Typora-like Markdown editor with document management",
    "longDescription": "Octothorpe is a fast, local-first Markdown editor that renders while you type (Typora-style), with Bear-style inline tags, full-text search (including Chinese), and a vault-based document manager.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
